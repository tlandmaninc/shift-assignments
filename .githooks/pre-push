#!/usr/bin/env bash
# ECT pre-push hook — runs backend + frontend tests before every push
# Activate with: git config core.hooksPath .githooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BACKEND_DIR="$REPO_ROOT/backend"
FRONTEND_DIR="$REPO_ROOT/frontend"

RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
NC=$'\033[0m'

echo ""
echo "========================================"
echo "   ECT Pre-Push Test Suite"
echo "========================================"

# ── Backend Tests (pytest) ──────────────────────────────────────────────────
echo ""
echo "${YELLOW}► Running backend tests (pytest)...${NC}"

cd "$BACKEND_DIR"

# Prefer uv if available; fall back to a Python with pytest installed
if command -v uv &>/dev/null; then
    if uv run python -m pytest tests/ -v --tb=short; then
        echo "${GREEN}✓ Backend tests passed${NC}"
        BACKEND_RESULT=0
    else
        echo "${RED}✗ Backend tests FAILED${NC}"
        BACKEND_RESULT=1
    fi
else
    # Fallback: pick the first Python that has pytest installed
    PYTHON=""
    for candidate in \
        "$BACKEND_DIR/.venv/bin/python" \
        "$BACKEND_DIR/venv/bin/python" \
        "$BACKEND_DIR/venv-wsl/bin/python" \
        "$REPO_ROOT/venv/bin/python" \
        "python3" \
        "python"; do
        if { [ -f "$candidate" ] || command -v "$candidate" &>/dev/null; } \
           && "$candidate" -c "import pytest" &>/dev/null 2>&1; then
            PYTHON="$candidate"
            break
        fi
    done

    if [ -z "$PYTHON" ]; then
        echo "${RED}✗ Could not find uv or a Python with pytest installed${NC}"
        exit 1
    fi

    if $PYTHON -m pytest tests/ -v --tb=short; then
        echo "${GREEN}✓ Backend tests passed${NC}"
        BACKEND_RESULT=0
    else
        echo "${RED}✗ Backend tests FAILED${NC}"
        BACKEND_RESULT=1
    fi
fi

# ── Frontend Tests (Jest) ───────────────────────────────────────────────────
echo ""
echo "${YELLOW}► Running frontend tests (Jest)...${NC}"

cd "$FRONTEND_DIR"
if [ -f "package.json" ] && node -e "const p=require('./package.json'); process.exit(p.scripts && p.scripts.test ? 0 : 1)" 2>/dev/null; then
    if npm test -- --watchAll=false --passWithNoTests; then
        echo "${GREEN}✓ Frontend tests passed${NC}"
        FRONTEND_RESULT=0
    else
        echo "${RED}✗ Frontend tests FAILED${NC}"
        FRONTEND_RESULT=1
    fi
else
    echo "${YELLOW}⚠ No frontend test script found — skipping${NC}"
    FRONTEND_RESULT=0
fi

# ── Summary ─────────────────────────────────────────────────────────────────
echo ""
echo "========================================"
if [ $BACKEND_RESULT -eq 0 ] && [ $FRONTEND_RESULT -eq 0 ]; then
    echo "${GREEN}  All tests passed — push approved ✓${NC}"
    echo "========================================"
    exit 0
else
    echo "${RED}  Tests FAILED — push blocked ✗${NC}"
    echo "========================================"
    [ $BACKEND_RESULT -ne 0 ] && echo "${RED}  • Backend tests failed${NC}"
    [ $FRONTEND_RESULT -ne 0 ] && echo "${RED}  • Frontend tests failed${NC}"
    echo ""
    echo "Fix the failing tests and try again."
    echo "========================================"
    exit 1
fi
