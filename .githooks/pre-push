#!/usr/bin/env bash
# ECT pre-push hook — runs backend + frontend tests before every push
# Activate with: git config core.hooksPath .githooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BACKEND_DIR="$REPO_ROOT/backend"
FRONTEND_DIR="$REPO_ROOT/frontend"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo "========================================"
echo "   ECT Pre-Push Test Suite"
echo "========================================"

# ── Backend Tests (pytest) ──────────────────────────────────────────────────
echo ""
echo "${YELLOW}► Running backend tests (pytest)...${NC}"

# Prefer the project virtual environment if it exists
if [ -f "$BACKEND_DIR/.venv/bin/python" ]; then
    PYTHON="$BACKEND_DIR/.venv/bin/python"
elif [ -f "$BACKEND_DIR/venv/bin/python" ]; then
    PYTHON="$BACKEND_DIR/venv/bin/python"
elif [ -f "$REPO_ROOT/venv/bin/python" ]; then
    PYTHON="$REPO_ROOT/venv/bin/python"
else
    PYTHON="python3"
fi

cd "$BACKEND_DIR"
if $PYTHON -m pytest tests/ -v --tb=short; then
    echo -e "${GREEN}✓ Backend tests passed${NC}"
    BACKEND_RESULT=0
else
    echo -e "${RED}✗ Backend tests FAILED${NC}"
    BACKEND_RESULT=1
fi

# ── Frontend Tests (Jest) ───────────────────────────────────────────────────
echo ""
echo "${YELLOW}► Running frontend tests (Jest)...${NC}"

cd "$FRONTEND_DIR"
if [ -f "package.json" ] && node -e "const p=require('./package.json'); process.exit(p.scripts && p.scripts.test ? 0 : 1)" 2>/dev/null; then
    if npm test -- --watchAll=false --passWithNoTests; then
        echo -e "${GREEN}✓ Frontend tests passed${NC}"
        FRONTEND_RESULT=0
    else
        echo -e "${RED}✗ Frontend tests FAILED${NC}"
        FRONTEND_RESULT=1
    fi
else
    echo -e "${YELLOW}⚠ No frontend test script found — skipping${NC}"
    FRONTEND_RESULT=0
fi

# ── Summary ─────────────────────────────────────────────────────────────────
echo ""
echo "========================================"
if [ $BACKEND_RESULT -eq 0 ] && [ $FRONTEND_RESULT -eq 0 ]; then
    echo -e "${GREEN}  All tests passed — push approved ✓${NC}"
    echo "========================================"
    exit 0
else
    echo -e "${RED}  Tests FAILED — push blocked ✗${NC}"
    echo "========================================"
    [ $BACKEND_RESULT -ne 0 ] && echo -e "${RED}  • Backend tests failed${NC}"
    [ $FRONTEND_RESULT -ne 0 ] && echo -e "${RED}  • Frontend tests failed${NC}"
    echo ""
    echo "Fix the failing tests and try again."
    echo "========================================"
    exit 1
fi
