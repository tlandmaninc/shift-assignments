# =============================================================================
# ECT Application Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# Application Settings
# Generate a new key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Environment: development or production
ENVIRONMENT=development

# =============================================================================
# AI Provider Configuration
# =============================================================================
# Supported providers: gemini, ollama, groq, together, openrouter, openai
# Default: gemini (free tier recommended for deployment)
AI_PROVIDER=gemini

# -----------------------------------------------------------------------------
# Gemini Configuration (FREE - RECOMMENDED)
# Get your free API key at: https://aistudio.google.com/app/apikey
# Free tier: 15 RPM, 1M tokens/min, 1500 requests/day
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Ollama Configuration (FREE - Local Development)
# Install from: https://ollama.ai
# Run locally: ollama serve
# -----------------------------------------------------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# -----------------------------------------------------------------------------
# OpenAI-Compatible APIs (Groq, Together, OpenRouter, OpenAI)
# Used when AI_PROVIDER is set to: groq, together, openrouter, or openai
# -----------------------------------------------------------------------------
# Groq (FREE): https://console.groq.com - 14,400 requests/day
# Together: https://api.together.xyz - Free tier available
# OpenRouter: https://openrouter.ai - Some free models
# OpenAI: https://platform.openai.com - Paid only
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# =============================================================================
# Google OAuth (Optional - for Google Forms integration)
# =============================================================================
# 1. Go to https://console.cloud.google.com/
# 2. Create a project or select existing one
# 3. Enable Google Forms API and Google Drive API
# 4. Go to APIs & Services > Credentials
# 5. Create OAuth 2.0 Client ID (Web application)
# 6. Add redirect URI (update for production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/google/callback

# Google Form Template (Optional - for header image)
# Create a template form in Google Forms with the header image configured,
# then copy the form ID from the URL: docs.google.com/forms/d/{FORM_ID}/edit
# New forms will be copied from this template, preserving the header image.
GOOGLE_FORM_TEMPLATE_ID=

# =============================================================================
# GitHub Integration (Placeholder for future use)
# =============================================================================
GITHUB_TOKEN=
GITHUB_REPO=
