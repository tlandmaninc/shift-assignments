# ============================================================
# ECT Shift Assignment App - Backend Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# ─── App Settings ──────────────────────────────────────────
SECRET_KEY=your-secret-key-minimum-32-characters-long-change-this
ENVIRONMENT=production
# Comma-separated list of admin email addresses.
# If empty, the first user to log in is auto-promoted to admin.
ADMIN_EMAILS=admin@yourdomain.com,another-admin@yourdomain.com

# ─── Frontend URL ──────────────────────────────────────────
FRONTEND_URL=https://your-frontend-domain.vercel.app

# ─── AI Provider ───────────────────────────────────────────
# Options: gemini, ollama, openai, groq, together, openrouter
AI_PROVIDER=gemini

# Google Gemini (recommended - free tier available)
GEMINI_API_KEY=your-gemini-api-key-from-aistudio.google.com
GEMINI_MODEL=gemini-2.5-flash

# Local Ollama (optional, for offline use)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (paid)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Groq (FREE - https://console.groq.com)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Together AI (https://api.together.xyz)
TOGETHER_API_KEY=your-together-api-key
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# ─── Google OAuth ──────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Google Forms Integration (optional) ───────────────────
GOOGLE_FORM_TEMPLATE_ID=your-google-form-template-id

# ─── Firebase / Phone OTP (optional) ───────────────────────
# Base64-encoded Firebase service account JSON
# Run: base64 -w0 firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_BASE64=your-base64-encoded-firebase-service-account

# Firebase project settings (from Firebase console)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
