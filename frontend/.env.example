# ============================================================
# ECT Shift Assignment App - Frontend Environment Configuration
# ============================================================
# For local development: copy to .env.local
# For Vercel: set these in your project's Environment Variables

# Backend API URL (for local dev, use http://localhost:8000)
NEXT_PUBLIC_API_URL=https://your-backend-on-render.onrender.com

# Firebase (optional - only if using phone OTP auth)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
